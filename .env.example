# 复制为 .env 并填入真实值，.env 不会提交到 Git

# 阿里云百炼 API Key（用于 AI 推荐）
BAILIAN_API_KEY=your_bailian_api_key

# 高德地图（前端与 Web 服务）
VITE_AMAP_KEY=your_amap_key
VITE_AMAP_WEB_KEY=your_amap_web_key
VITE_AMAP_SECURITY_CODE=your_amap_security_code

# 后端 API 地址（本地开发可用 localhost，部署时改为实际域名）
VITE_AI_API=http://localhost:3000/api/ai-assistant
VITE_BASE_API=http://localhost:3000/api

# 学校列表（JSON，name + center 经纬度）
VITE_UNIVERSITIES=[{"name":"北航","center":"116.270541,40.15354"},{"name":"矿大","center":"116.261576,40.152721"},{"name":"北师大","center":"116.263685,40.149461"}]
